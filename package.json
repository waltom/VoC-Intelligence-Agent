{
  "name": "voc-intelligence-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic AI system analyzing public customer reviews and generating business reports.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "deploy": "pnpm -r deploy",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf .next dist .wrangler node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "wrangler": "^4.88.0"
  }
}
