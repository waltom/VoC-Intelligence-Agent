{
  "name": "@voc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "d1:migrate:local": "wrangler d1 migrations apply voc_db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply voc_db --remote",
    "d1:create": "wrangler d1 create voc_db",
    "vectorize:create": "wrangler vectorize create voc-reviews --dimensions=1024 --metric=cosine",
    "r2:create": "wrangler r2 bucket create voc-reports",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@voc/shared": "workspace:*",
    "hono": "^4.6.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@worker-tools/html-rewriter": "^0.1.0-pre.18",
    "typescript": "^5.6.3",
    "vitest": "2.1.4",
    "wrangler": "^4.88.0"
  }
}
